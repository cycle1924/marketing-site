---
// Single source of truth for the PeelForward brand mark and wordmark.
// Included in the shared layout's header and footer, so a future brand
// swap touches this one file. The header sits on a light surface and uses
// the blue-dot mark; the footer sits on the navy surface and uses the
// white-dot mark. Wordmark colors are driven by tokens (see tokens.css).
interface Props {
  variant?: 'header' | 'footer';
}
const { variant = 'header' }: Props = Astro.props;
const mark = variant === 'footer' ? '/peel-icon-white-dot.png' : '/peel-icon-blue-dot.png';
---
<a class="brand" href="/" aria-label="PeelForward home">
  <span class="mark">
    <img src={mark} width="34" height="34" alt="" />
  </span>
  <span class="word"><b>Peel</b><span>Forward</span></span>
</a>

<style>
  .brand .mark img { width: 34px; height: 34px; display: block; }
</style>
