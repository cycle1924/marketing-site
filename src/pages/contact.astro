---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="PeelForward: Contact us"
  description="Questions about PeelForward or Peel Signal Theory? Send us a note and a member of our team will get back to you."
>

<section class="contact-hero">
  <div class="container">
    <div class="inner">
      <span class="eyebrow">Contact</span>
      <h1>Get in touch.</h1>
      <p class="lead">Have a question about PeelForward or Peel Signal Theory? Send us a note and a member of our team will get back to you.</p>
    </div>
  </div>
</section>

<section class="section container">
  <div class="contact-col">
    <!-- Form -->
    <div class="form-card" id="formCard">
      <h2>Contact us</h2>
      <p class="sub">Tell us a little about what you're looking for. Only your email is required.</p>
      <form id="contactForm" novalidate>
        <div class="field-row">
          <div class="field">
            <label for="fn">First name <span class="opt">(optional)</span></label>
            <input class="input" id="fn" name="firstname" type="text" placeholder="John" />
          </div>
          <div class="field">
            <label for="ln">Last name <span class="opt">(optional)</span></label>
            <input class="input" id="ln" name="lastname" type="text" placeholder="Doe" />
          </div>
        </div>
        <div class="field">
          <label for="em">Email</label>
          <input class="input" id="em" name="email" type="email" placeholder="john@example.com" required />
        </div>
        <div class="field">
          <label for="co">Company <span class="opt">(optional)</span></label>
          <input class="input" id="co" name="company" type="text" placeholder="Acme Inc" />
        </div>
        <div class="field">
          <label for="msg">Message <span class="opt">(optional)</span></label>
          <textarea class="textarea" id="msg" name="message" placeholder="How can we help?"></textarea>
        </div>
        <button class="btn btn-primary btn-lg btn-block" type="submit">Send message</button>
      </form>
    </div>

    <!-- Success state -->
    <div class="form-card hidden" id="successCard">
      <div class="success">
        <div class="check">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h2>Message received.</h2>
        <p>Thanks for reaching out. A member of our team will get back to you by email shortly.</p>
        <a href="/" class="btn btn-secondary success-back">Back to home</a>
      </div>
    </div>
  </div>
</section>

</Layout>

<script>
  import { wireHubspotForm } from '../scripts/hubspotForm';
  wireHubspotForm({ formId: 'contactForm', cardId: 'formCard', successId: 'successCard', which: 'contact' });
</script>

<style>
  .contact-hero { background: linear-gradient(180deg, var(--color-white), var(--color-bg-neutral)); border-bottom: 1px solid var(--color-border); }
  .contact-hero .inner { text-align: center; max-width: 56ch; margin-inline: auto; padding-block: var(--pad-hero-bottom); }
  .contact-hero h1 { margin: var(--space-14) 0 var(--space-16); }
  .contact-hero .lead { margin-inline: auto; }

  .contact-col { max-width: 640px; margin-inline: auto; }
  .form-card {
    background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--r-xl);
    padding: var(--pad-form-card); box-shadow: var(--shadow-md);
  }
  .form-card h2 { font-size: var(--fs-140); margin-bottom: var(--space-6); }
  .form-card .sub { color: var(--color-text-muted); font-size: var(--fs-096); margin-bottom: var(--space-26); }

  .success { text-align: center; padding: var(--space-14) 0; }
  .success .check {
    width: 64px; height: 64px; border-radius: var(--r-circle); margin: 0 auto var(--space-20);
    background: var(--color-accent-soft); color: var(--color-accent); display: grid; place-items: center;
  }
  .success h2 { margin-bottom: var(--space-10); }
  .success p { color: var(--color-text-muted); max-width: 40ch; margin-inline: auto; }
  .success-back { margin-top: var(--space-24); }
</style>
