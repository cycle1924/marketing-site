---
import Layout from '../layouts/Layout.astro';

// AI-readiness cards are data driven. To edit, add, or reorder cards later,
// change this one array only, matching the data-driven pattern used by the
// pricing grid.
interface ReadinessCard {
  title: string;
  body: string;
}

const readinessCards: ReadinessCard[] = [
  {
    title: 'Acts on the answer.',
    body: 'We do not hand you a readiness grade and walk away. PeelForward pinpoints the processes where AI genuinely fits and helps you put it to work there. For the rest, it drives continuous improvement so the whole operation moves forward, not just the AI-ready corners.',
  },
  {
    title: 'Your people decide.',
    body: 'PeelForward computes the facts and lays them out plainly. Every judgment that matters stays with your team. The platform never overrules a person and never hides how it reached a conclusion. You get clarity, not a black box.',
  },
  {
    title: 'Proof, not promises.',
    body: 'Every change is measured against where you started, so you can show the people funding the work exactly what improved and what it was worth. Readiness becomes results you can defend.',
  },
];
---
<Layout
  title="PeelForward: AI readiness for real operations"
  description="PeelForward finds the processes where AI genuinely fits, automates those well, and drives measured continuous improvement everywhere else. The decisions stay yours."
>

<!-- ============ HERO ============ -->
<section class="hero">
  <div class="container">
    <div class="hero-copy hero-inner">
      <span class="eyebrow">AI readiness for real operations</span>
      <h1>Put AI where it belongs.</h1>
      <p class="reassurance">The decisions stay yours. The guesswork goes away.</p>
      <p class="lead">Told to "make AI work," most companies scatter it across processes that were never good candidates. PeelForward finds the few where AI genuinely fits and helps you automate those well. For everything else, it drives continuous improvement and proves it worked, every change measured so you can show what it returned.</p>
      <div class="hero-actions">
        <a href="/demo" class="btn btn-primary btn-lg">Book a demo <span class="arrow">→</span></a>
        <a href="/whitepaper" class="btn btn-secondary btn-lg">Read the framework</a>
      </div>
    </div>
  </div>
</section>

<!-- ============ HERITAGE STRIP ============ -->
<div class="heritage">
  <div class="container">
    <p><b>A century of operational science,</b> rebuilt with AI to move your operation forward.</p>
  </div>
</div>

<!-- ============ AI READINESS ============ -->
<section class="readiness section container">
  <div class="center readiness-intro">
    <h2>The honest answer to "are we AI ready?"</h2>
    <p class="lead">Every leader is being asked that question. The usual answer is a score and a slide deck. PeelForward gives you something you can act on.</p>
  </div>
  <div class="readiness-grid">
    {readinessCards.map((card) => (
      <article class="readiness-card">
        <span class="readiness-rule" aria-hidden="true"></span>
        <h3 class="readiness-card-title">{card.title}</h3>
        <p class="readiness-card-body">{card.body}</p>
      </article>
    ))}
  </div>
</section>

<!-- ============ HOW IT WORKS (merged flow) ============ -->
<section class="flow-section section container">
  <p class="flow-transition center">How it finds all of this: by listening to the signals already in your data.</p>
  <div class="center flow-intro">
    <span class="eyebrow">How it works</span>
    <h2>From the data you already have to the moves that matter.</h2>
  </div>
  <div class="flow">
    <!-- Stage 1 -->
    <div class="flow-stage">
      <span class="flow-step">Stage 1</span>
      <span class="flow-title">Plugs into your data.</span>
      <div class="flow-body">
        <div class="data-tiles">
          <span class="tile" title="Databases"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/></svg></span>
          <span class="tile" title="ERP"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></span>
          <span class="tile" title="Spreadsheets"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="3" x2="9" y2="21"/></svg></span>
          <span class="tile" title="Sensors"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l3 8 4-16 3 8h4"/></svg></span>
          <span class="tile" title="CRM"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg></span>
          <span class="tile" title="Cloud"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg></span>
        </div>
        <p class="flow-copy">PeelForward connects to the systems your business already runs on. No rip and replace. Your data starts working for you.</p>
      </div>
    </div>

    <div class="flow-arrow" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </div>

    <!-- Stage 2 -->
    <div class="flow-stage">
      <span class="flow-step">Stage 2</span>
      <span class="flow-title">Surfaces what matters.</span>
      <div class="flow-body">
        <div class="signal-chips">
          <span class="chip">Drift</span>
          <span class="chip">Leading</span>
          <span class="chip">Constraint</span>
          <span class="chip">Outcome</span>
          <span class="chip">Gap</span>
          <span class="chip">Readiness</span>
          <span class="chip">Damping</span>
        </div>
        <p class="flow-copy">Seven signal types continuously watch your operation and flag where performance is drifting, where constraints are forming, and where opportunity is hiding.</p>
      </div>
    </div>

    <div class="flow-arrow" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </div>

    <!-- Stage 3 -->
    <div class="flow-stage">
      <span class="flow-step">Stage 3</span>
      <span class="flow-title">Guides the fix, not just the finding.</span>
      <div class="flow-body">
        <div class="check-list">
          <div class="row"><span class="tick"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Find the constraint</div>
          <div class="row"><span class="tick"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Trace the root cause</div>
          <div class="row todo"><span class="tick"></span>Assign the fix</div>
        </div>
        <p class="flow-copy">Built-in root cause analysis and AI guidance walk your team from symptom to source to solution. You stay in control of every decision; the platform does the heavy lifting.</p>
      </div>
    </div>
  </div>

  <!-- Closing strip -->
  <div class="closing-strip">
    <span class="ico">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    </span>
    <div>
      <h3>Simple enough for everyone.</h3>
      <p>No black belts required. Plain-language insights your whole team can act on, backed by a century of proven method.</p>
    </div>
  </div>
</section>

<!-- ============ PRICING CALLOUT ============ -->
<section class="section container">
  <div class="callout">
    <div>
      <span class="eyebrow">Pricing</span>
      <h2>Simple, transparent pricing.</h2>
      <p>Three tiers that scale with your operation, based on how many lifecycles you manage. Implementation services are scoped separately by your consultant.</p>
      <a href="/pricing" class="btn btn-primary btn-lg callout-cta">See all plans <span class="arrow">→</span></a>
    </div>
    <div class="callout-tiers">
      <div class="tier-mini"><span class="name">Foundation</span><span class="price">$30K<span class="per">/yr</span></span></div>
      <div class="tier-mini"><span class="name">Standard</span><span class="price">$72K<span class="per">/yr</span></span></div>
      <div class="tier-mini"><span class="name">Enterprise</span><span class="price contact">Contact sales</span></div>
    </div>
  </div>
</section>

</Layout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(1100px 520px at 78% -8%, var(--color-accent-soft) 0%, transparent 60%),
      linear-gradient(180deg, var(--color-white) 0%, var(--color-bg-neutral) 100%);
    border-bottom: 1px solid var(--color-border);
  }
  .hero-inner {
    text-align: center;
    padding-block: var(--pad-hero-top) var(--pad-hero-bottom);
    max-width: 62ch;
    margin-inline: auto;
  }
  .hero-copy .eyebrow { margin-bottom: var(--space-20); display: inline-block; }
  .hero-copy h1 { margin-bottom: var(--space-14); }
  .hero-copy .reassurance {
    color: var(--color-navy);
    font-size: clamp(1.3rem, 2.2vw, 1.7rem);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-tight-3);
    line-height: var(--lh-snug);
    margin: 0 auto var(--space-22);
    max-width: 48ch;
  }
  .hero-copy .lead { max-width: 56ch; margin: 0 auto var(--space-32); }
  .hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-14); align-items: center; justify-content: center; }

  /* ---------- Heritage strip ---------- */
  .heritage {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-neutral);
  }
  .heritage p {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--fs-095);
    padding-block: var(--space-18);
    letter-spacing: var(--ls-wide-5);
  }
  .heritage b { color: var(--color-text); font-weight: var(--fw-bold); }

  /* ---------- AI readiness ---------- */
  .readiness-intro { margin-bottom: var(--space-48); max-width: 64ch; margin-inline: auto; }
  .readiness-intro h2 { margin-bottom: var(--space-16); }
  .readiness-intro .lead { max-width: 60ch; margin-inline: auto; }
  .readiness-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-24);
  }
  .readiness-card {
    background: var(--color-navy);
    color: var(--color-white);
    border-radius: var(--r-xl);
    padding: var(--space-36) var(--space-32);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
  }
  .readiness-rule {
    display: block;
    width: 48px;
    height: 4px;
    border-radius: var(--r-pill);
    background: var(--color-accent);
    margin-bottom: var(--space-22);
  }
  .readiness-card-title {
    color: var(--color-accent);
    font-size: var(--fs-130);
    font-weight: var(--fw-extrabold);
    letter-spacing: var(--ls-tight-3);
    margin-bottom: var(--space-16);
  }
  .readiness-card-body {
    color: var(--color-white);
    font-size: var(--fs-100);
    line-height: var(--lh-copy);
  }
  @media (max-width: 860px) {
    .readiness-grid { grid-template-columns: 1fr; }
  }

  /* ---------- Flow transition ---------- */
  .flow-transition {
    color: var(--color-slate-600);
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    max-width: 64ch;
    margin: 0 auto var(--space-44);
  }

  /* ---------- Flow diagram ---------- */
  .flow-intro { margin-bottom: var(--space-52); max-width: 64ch; margin-inline: auto; }
  .flow-intro h2 { margin-top: var(--space-14); }
  .flow-section { background: var(--color-bg); }
  .flow {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: stretch;
    gap: var(--space-18);
  }
  .flow-stage {
    background: var(--color-bg-neutral);
    border: 1px solid var(--color-border);
    border-radius: var(--r-lg);
    padding: var(--space-26) var(--space-24);
    display: flex;
    flex-direction: column;
  }
  .flow-step { font-size: var(--fs-074); font-weight: var(--fw-bold); letter-spacing: var(--ls-wide-2); text-transform: uppercase; color: var(--color-text-muted); }
  .flow-title { font-size: var(--fs-118); font-weight: var(--fw-extrabold); letter-spacing: var(--ls-tight-3); margin: var(--space-6) 0 var(--space-18); }
  .flow-body { margin-top: var(--space-4); }
  .flow-copy { color: var(--color-text-muted); font-size: var(--fs-096); margin-top: var(--space-16); line-height: var(--lh-lead); }
  .flow-arrow { display: grid; place-items: center; color: var(--color-slate-300); }

  /* ---------- Closing strip ---------- */
  .closing-strip {
    margin-top: var(--space-24);
    display: flex; align-items: center; gap: var(--space-22);
    background: var(--color-white); border: 1px solid var(--color-border);
    border-radius: var(--r-lg); padding: var(--space-26) var(--space-32);
  }
  .closing-strip .ico {
    width: 50px; height: 50px; flex: none; border-radius: var(--r-14);
    background: var(--color-accent-soft); color: var(--color-accent);
    display: grid; place-items: center;
  }
  .closing-strip h3 { margin-bottom: var(--space-4); }
  .closing-strip p { color: var(--color-text-muted); max-width: 80ch; }
  @media (max-width: 560px) { .closing-strip { flex-direction: column; align-items: flex-start; gap: var(--space-14); } }

  /* Stage 1: data tiles */
  .data-tiles { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-10); }
  .data-tiles .tile {
    aspect-ratio: 1; border-radius: var(--r-11); background: var(--color-white); border: 1px solid var(--color-border);
    display: grid; place-items: center; color: var(--color-text-muted);
  }
  .data-tiles .tile svg { width: 22px; height: 22px; }

  /* Stage 2: signal chips */
  .signal-chips { display: flex; flex-wrap: wrap; gap: var(--space-8); }
  .signal-chips .chip {
    display: inline-flex; align-items: center; gap: var(--space-7);
    padding: var(--space-7) var(--space-13); border-radius: var(--r-pill);
    background: var(--color-white); border: 1px solid var(--color-border);
    font-size: var(--fs-086); font-weight: var(--fw-semibold); color: var(--color-text);
  }

  /* Stage 3: checklist */
  .check-list { display: grid; gap: var(--space-11); }
  .check-list .row {
    display: flex; align-items: center; gap: var(--space-11);
    padding: var(--space-11) var(--space-14); border-radius: var(--r-10);
    background: var(--color-white); border: 1px solid var(--color-border);
    font-size: var(--fs-092); font-weight: var(--fw-semibold);
  }
  .check-list .row .tick {
    width: 20px; height: 20px; border-radius: var(--r-6); flex: none;
    background: var(--color-accent-soft); color: var(--color-accent);
    display: grid; place-items: center;
  }
  .check-list .row.todo { color: var(--color-text-muted); }
  .check-list .row.todo .tick { background: var(--color-bg-neutral-2); color: var(--color-slate-400); }

  @media (max-width: 860px) {
    .flow {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }
    .flow-arrow { transform: rotate(90deg); padding: var(--space-2) 0; }
  }

  /* ---------- Pricing callout ---------- */
  .callout {
    background: var(--color-ink-900);
    color: var(--color-white);
    border-radius: var(--r-xl);
    padding: var(--pad-callout);
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--space-40);
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .callout::after {
    content: "";
    position: absolute; right: -120px; top: -120px;
    width: 360px; height: 360px; border-radius: var(--r-circle);
    background: radial-gradient(circle, var(--color-accent-glow), transparent 65%);
  }
  .callout .eyebrow { color: var(--color-accent-light); }
  .callout h2 { color: var(--color-white); margin-top: var(--space-14); margin-bottom: var(--space-14); }
  .callout p { color: var(--color-slate-300); max-width: 46ch; }
  .callout-cta { margin-top: var(--space-24); }
  .callout-tiers { display: grid; gap: var(--space-14); position: relative; }
  .tier-mini {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: var(--space-16);
    padding: var(--space-16) var(--space-20);
    border-radius: var(--r-md);
    background: var(--color-overlay-05);
    border: 1px solid var(--color-overlay-10);
  }
  .tier-mini .name { font-weight: var(--fw-bold); }
  .tier-mini .price { color: var(--color-accent-light); font-weight: var(--fw-bold); }
  .tier-mini .price .per { color: var(--color-text-muted); font-weight: var(--fw-medium); }
  .tier-mini .price.contact { color: var(--color-slate-300); }
  @media (max-width: 800px) { .callout { grid-template-columns: 1fr; gap: var(--space-28); } }
</style>
